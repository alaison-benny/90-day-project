################################################################################
# 1. VPC Module (Virtual Private Cloud)
# ലളിതമായി പറഞ്ഞാൽ, AWS എന്ന വലിയ കാടിനുള്ളിൽ ചേട്ടായിക്ക് മാത്രമായി പണിത 
# ഒരു സുരക്ഷിതമായ കോട്ടയാണ് VPC.
################################################################################

module "vpc" {
  source  = "terraform-aws-modules/vpc/aws"
  version = "5.0.0"

  name = "eks-vpc"
  
  # cidr = "10.0.0.0/16": ഇത് ചേട്ടായിയുടെ കോട്ടയ്ക്കുള്ളിലെ മൊത്തം ഐപി 
  # അഡ്രസ്സുകളുടെ എണ്ണമാണ്. ഏകദേശം 65,000+ ഐപികൾ ഇതിൽ കിട്ടും.
  cidr = "10.0.0.0/16"

  # azs = ["us-east-1a", ...]: ഇതിനെ Availability Zones എന്ന് വിളിക്കുന്നു.
  # റിയൽ-ലൈഫ് ഉദാഹരണം: ഒരു ബിൽഡിംഗിൽ മാത്രം സെർവർ വെച്ചാൽ അവിടെ തീപിടുത്തം 
  # ഉണ്ടായാൽ എല്ലാം പോകും. അതുകൊണ്ട് നമ്മൾ 3 വ്യത്യസ്ത ബിൽഡിംഗുകളിലായി 
  # സെർവറുകൾ വിഭജിച്ചു വെക്കുന്നു (High Availability).
  azs             = ["us-east-1a", "us-east-1b", "us-east-1c"]

  # private_subnets: ഇവിടെയാണ് ഡാറ്റാബേസും മെയിൻ ആപ്ലിക്കേഷനും ഇരിക്കുന്നത്. 
  # ഇതിലേക്ക് ഇന്റർനെറ്റിൽ നിന്ന് ആർക്കും നേരിട്ട് കയറാൻ പറ്റില്ല (സുരക്ഷ).
  private_subnets = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]

  # public_subnets: ഇതിലാണ് Load Balancer-കൾ ഇരിക്കുന്നത്. 
  # പുറംലോകത്തിന് കാണാൻ കഴിയുന്ന ഭാഗമാണിത്.
  public_subnets  = ["10.0.4.0/24", "10.0.5.0/24", "10.0.6.0/24"]

  # enable_nat_gateway = true: പ്രൈവറ്റ് സബ്‌നെറ്റിലുള്ള സെർവറുകൾക്ക് 
  # പുറത്തുള്ള ഇന്റർനെറ്റിൽ നിന്ന് അപ്‌ഡേറ്റുകൾ ഡൗൺലോഡ് ചെയ്യാൻ ഇത് വേണം.
  enable_nat_gateway = true
  single_nat_gateway = true
}

################################################################################
# 2. EKS Module (Elastic Kubernetes Service)
# നമ്മുടെ ആപ്ലിക്കേഷനുകൾ നിയന്ത്രിക്കുന്ന 'തലച്ചോറാണ്' ഈ EKS.
################################################################################

module "eks" {
  source          = "terraform-aws-modules/eks/aws"
  
  # cluster_name & cluster_version: ക്ലസ്റ്ററിന്റെ പേരും കുബെർനെറ്റിസ് വേർഷനും.
  cluster_name    = var.cluster_name
  cluster_version = var.cluster_version

  # subnets = module.vpc.private_subnets: ഇത് വളരെ പ്രധാനമാണ്! 
  # വർക്കർ നോഡുകളെ Private Subnet-ൽ മാത്രമേ വെക്കാറുള്ളൂ. 
  # ഹാക്കർമാർക്ക് നേരിട്ട് സെർവറുകളിൽ കയറാൻ പറ്റാതിരിക്കാനാണ് ഇത്.
  subnets         = module.vpc.private_subnets

  # 3. എങ്ങനെയാണ് ഈ രണ്ട് മൊഡ്യൂളുകൾ തമ്മിൽ സംസാരിക്കുന്നത്?
  # vpc_id = module.vpc.vpc_id: ആദ്യം VPC കോട്ട പണിയും, എന്നിട്ട് ആ 
  # കോട്ടയുടെ ഐഡി EKS-ന് കൈമാറും. അങ്ങനെ EKS-ന് തന്റെ ലൊക്കേഷൻ മനസ്സിലാകും.
  vpc_id          = module.vpc.vpc_id

  # node_groups: ഇതാണ് യഥാർത്ഥത്തിൽ നമ്മുടെ ആപ്പുകൾ റൺ ചെയ്യുന്ന കമ്പ്യൂട്ടറുകൾ.
  node_groups = {
    default = {
      # desired_capacity: സാധാരണ സമയത്ത് എത്ര സെർവർ വേണം.
      desired_capacity = var.desired_capacity
      # max_capacity: ട്രാഫിക് കൂടിയാൽ പരമാവധി എത്ര സെർവർ വരെ ആകാം.
      # റിയൽ-ലൈഫ് ഉദാഹരണം: സെയിൽ വരുമ്പോൾ ട്രാഫിക് കൂടുമ്പോൾ തനിയെ 
      # സെർവറുകൾ വർദ്ധിക്കും (Auto Scaling).
      max_capacity     = var.max_capacity
      # min_capacity: ലോഡ് കുറഞ്ഞാലും മിനിമം ഇത്ര സെർവർ എപ്പോഴും ഓടണം.
      min_capacity     = var.min_capacity

      instance_type = var.instance_type
    }
  }
}

# അടുത്ത സ്റ്റെപ്പ്:
# ഈ ഫയൽ സേവ് ചെയ്ത ശേഷം 'terraform plan' അടിച്ചു നോക്കൂ. 
# ഏകദേശം 50-ൽ അധികം റിസോഴ്‌സുകൾ ലിസ്റ്റ് ചെയ്യുന്നത് കാണാം.
